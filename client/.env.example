# Leave REACT_APP_API_URL unset when the frontend and API are served from the same Render service.
# Only set it if you split the frontend and backend across different domains.
# REACT_APP_API_URL=https://your-render-service.onrender.com

# EmailJS settings for new-account verification emails.
# Expected template variables:
# {{to_email}}, {{to_name}}, {{verification_code}}, {{app_name}}, {{account_type}}, {{reply_to}}
# REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
# REACT_APP_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
# REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# REACT_APP_EMAILJS_APP_NAME=JumpTake
# REACT_APP_EMAILJS_REPLY_TO=no-reply@jumptake.com
# REACT_APP_EMAIL_VERIFICATION_EXPIRY_MINUTES=10

# Optional dedicated EmailJS settings for forgot-password reset emails.
# Expected template variables:
# {{to_email}}, {{to_name}}, {{reset_link}}, {{app_name}}, {{account_type}}, {{reply_to}}
# REACT_APP_EMAILJS_PASSWORD_RESET_SERVICE_ID=your_password_reset_service_id
# REACT_APP_EMAILJS_PASSWORD_RESET_TEMPLATE_ID=your_password_reset_template_id
# REACT_APP_EMAILJS_PASSWORD_RESET_PUBLIC_KEY=your_password_reset_public_key
